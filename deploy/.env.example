# 必填:JWT 签名密钥,生成方式: openssl rand -hex 32
JWT_SECRET=

# 上游 token 落库加密的主密钥(强烈建议设置): openssl rand -hex 32
# 留空则从 JWT_SECRET 派生(可用但不推荐生产);一旦设置请勿更换,否则已存的上游 key 无法解密
ENCRYPTION_KEY=

# 管理员账号(首次启动自动创建;密码留空则随机生成并打印到日志)
ADMIN_EMAIL=admin@dengdeng.local
ADMIN_PASSWORD=

# 站点
SITE_NAME=蹬蹬中转
SITE_PUBLIC_URL=https://relay.example.com
SITE_ALLOW_REGISTER=true

# 管理端仓库更新（仅在安装 deploy/update 后启用）
UPDATE_ENABLED=false
UPDATE_REPOSITORY=https://github.com/Lincb522/dengdeng.git
UPDATE_BRANCH=main
UPDATE_STATE_DIRECTORY=/var/lib/dengdeng/update

# 可选: 上游 OAuth 应用注册信息。生产环境必须把相同的 callback URL
# 登记到上游，再填写对应的 client ID / secret。
# OAUTH_OPENAI_CLIENT_ID=
# OAUTH_OPENAI_CLIENT_SECRET=
# OAUTH_OPENAI_REDIRECT_URL=https://relay.example.com/api/admin/oauth/openai/callback
# OAUTH_ANTHROPIC_CLIENT_ID=
# OAUTH_ANTHROPIC_CLIENT_SECRET=
# OAUTH_ANTHROPIC_REDIRECT_URL=https://relay.example.com/api/admin/oauth/anthropic/callback

# 监听(生产建议 127.0.0.1 + 反代 HTTPS)
BIND_HOST=127.0.0.1
SERVER_PORT=9100

TZ=Asia/Shanghai

# 使用 PostgreSQL 时启用
# POSTGRES_PASSWORD=
